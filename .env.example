# ===========================================
# FLIGHT DELAY PREDICTION - Configuration
# ===========================================

# AviationStack API
AVIATIONSTACK_API_KEY=your_aviationstack_key_here

# Lufthansa API (Optional)
LUFTHANSA_CLIENT_ID=your_lufthansa_client_id
LUFTHANSA_SECRET=your_lufthansa_secret

# Air France-KLM API (Optional - Contract Pending)
AIRFRANCE_API_KEY=your_airfrance_api_key
AIRFRANCE_CLIENT_ID=your_airfrance_client_id
AIRFRANCE_CLIENT_SECRET=your_airfrance_secret

# OpenWeatherMap API
OPENWEATHER_API_KEY=your_openweather_key_here

# MongoDB Atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database_name

# Supabase PostgreSQL
SUPABASE_DB_URL=postgresql://postgres.xxx:password@aws-1-region.pooler.supabase.com:5432/postgres

# Snowflake
SNOWFLAKE_ACCOUNT=YOUR_ACCOUNT_IDENTIFIER
SNOWFLAKE_USER=your_username
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_WAREHOUSE=your_warehouse
SNOWFLAKE_DATABASE=your_database
